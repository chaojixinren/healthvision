# Copy this file to .env.production on the server and fill real secrets.
# Do not commit the filled .env.production file.

MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
MYSQL_DATABASE=healthvision

BACKEND_PORT=8080
BACKEND_IMAGE=chaojixinren/healthvision-backend:latest
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ISSUER=healthvision
ACCESS_TOKEN_TTL=24h
REFRESH_TOKEN_TTL=720h

LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-real-llm-api-key
AGENT_REQUIRE_WRITE_TOOL_CONFIRMATION=true

CHAT_RETENTION_DAYS=30
CHAT_MAX_MESSAGES_PER_USER=2000
